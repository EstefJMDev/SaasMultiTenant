# Variables de entorno para el backend FastAPI
# Copia este archivo como .env y rellena los valores reales.
# NUNCA cometas .env con secretos reales al repositorio.

ENV=local
DEBUG=false

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5433/saas

SECRET_KEY=cambia-esto-por-un-secreto-seguro-de-al-menos-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
MFA_ENABLED=true
ALLOW_BOOTSTRAP_SUPERADMIN=false
SUPERADMIN_EMAIL=admin@tudominio.com
SUPERADMIN_PASSWORD=cambia-esto
ALGORITHM=HS256

# Config multi-tenant
PRIMARY_DOMAIN=tudominio.com

# URL base del frontend para enlaces y CORS
FRONTEND_BASE_URL=http://localhost:5173
PLATFORM_DISPLAY_NAME=SaaS Platform
FRONTEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Signaturit
PUBLIC_API_BASE_URL=https://api.tudominio.com
SIGNATURIT_BASE_URL=https://api.sandbox.signaturit.com/v3
SIGNATURIT_API_TOKEN=
SIGNATURIT_EVENTS_URL=
SIGNATURIT_WEBHOOK_TOKEN=
SIGNATURIT_TIMEOUT_SECONDS=30
SIGNATURIT_DEFAULT_SIGNATURE_MODE=certificate

# SMTP (opcional, para correos de bienvenida/verificacion)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# OCR / LLM (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_COMPARATIVE_OCR_TIMEOUT_SECONDS=180
OLLAMA_COMPARATIVE_JSON_TIMEOUT_SECONDS=180
OLLAMA_COMPARATIVE_STRICT_MODE=false
OLLAMA_COMPARATIVE_OCR_MAX_PAGES=5
OLLAMA_COMPARATIVE_OCR_DPI=300

# Emails para facturas
INVOICE_CREATED_EXTRA_RECIPIENTS=[]
INVOICE_DUE_BASE_RECIPIENTS=["contabilidad@tudominio.com"]
INVOICE_DUE_EXTRA_RECIPIENTS_10=["direccion@tudominio.com"]
INVOICE_DUE_EXTRA_RECIPIENTS_5=["gerencia@tudominio.com"]

# Moodle Web Services (opcional)
MOODLE_BASE_URL=http://moodle
MOODLE_TOKEN=

# Internal notifications from ERP
SAAS_INTERNAL_API_KEY=cambia-esto-por-un-secreto-seguro

CONTRACTS_STORAGE_PATH=./data/contracts
SIGNATURE_REQUEST_TTL_HOURS=336

# Telegram bridge (bot -> agent-system)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_AGENT_BASE_URL=http://localhost:3000
TELEGRAM_DEFAULT_TENANT_ID=1
TELEGRAM_REQUEST_TIMEOUT_SECONDS=180
TELEGRAM_VOICE_ENABLED=false
TELEGRAM_VOICE_REPLY_ENABLED=false
TELEGRAM_VOICE_MAX_DURATION_SECONDS=180
TELEGRAM_VOICE_MAX_BYTES=20971520
TELEGRAM_IMAGE_ENABLED=false
TELEGRAM_IMAGE_MAX_BYTES=20971520
TELEGRAM_IMAGE_OCR_MAX_CHARS=3000
TELEGRAM_VOICE_PROVIDER=local
TELEGRAM_STT_MODEL=whisper-1
TELEGRAM_TTS_MODEL=tts-1
TELEGRAM_TTS_VOICE=alloy
TELEGRAM_TTS_FORMAT=mp3
TELEGRAM_LOCAL_STT_MODEL=small
TELEGRAM_LOCAL_STT_DEVICE=cpu
TELEGRAM_LOCAL_STT_COMPUTE_TYPE=int8
TELEGRAM_LOCAL_STT_LANGUAGE=es
TELEGRAM_LOCAL_TTS_ENGINE=piper
TELEGRAM_LOCAL_TTS_FALLBACK_ENGINE=gtts
TELEGRAM_LOCAL_TTS_SPEED_MIN=0.7
TELEGRAM_LOCAL_TTS_SPEED_MAX=1.6
TELEGRAM_LOCAL_TTS_GTTS_LANG=es
TELEGRAM_LOCAL_TTS_GTTS_TLD=es
TELEGRAM_LOCAL_TTS_EDGE_VOICE=es-ES-ElviraNeural
TELEGRAM_LOCAL_TTS_EDGE_RATE=+0%
TELEGRAM_LOCAL_TTS_VOICE=es
TELEGRAM_LOCAL_TTS_SPEED=155
TELEGRAM_LOCAL_TTS_PIPER_BIN=piper
TELEGRAM_LOCAL_TTS_PIPER_MODEL_PATH=/app/models/piper/es_ES-carlfm-x_low.onnx
TELEGRAM_LOCAL_TTS_PIPER_CONFIG_PATH=/app/models/piper/es_ES-carlfm-x_low.onnx.json
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
