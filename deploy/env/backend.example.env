ENV=local
DEBUG=true

DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/saas
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
MFA_ENABLED=false

ALLOW_BOOTSTRAP_SUPERADMIN=true
SUPERADMIN_EMAIL=change-me@local.test
SUPERADMIN_PASSWORD=change-me

PRIMARY_DOMAIN=localhost

FRONTEND_BASE_URL=http://localhost:5173
FRONTEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://host.docker.internal:5173"]

PUBLIC_API_BASE_URL=http://localhost:8000
PLATFORM_DISPLAY_NAME=Plataforma URDECON Local

INVOICES_STORAGE_PATH=/data/invoices
CONTRACTS_STORAGE_PATH=/data/contracts

OLLAMA_BASE_URL=http://host.docker.internal:11434

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

SAAS_INTERNAL_API_KEY=change-me

SIGNATURIT_API_TOKEN=
SIGNATURIT_WEBHOOK_TOKEN=
SIGNATURIT_BASE_URL=https://api.sandbox.signaturit.com/v3
SIGNATURIT_DEFAULT_SIGNATURE_MODE=certificate
