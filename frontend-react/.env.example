# URL publica de la API FastAPI en produccion
VITE_API_BASE_URL=https://api.mavico.shop
# En dev (:5173), por defecto se usa proxy local para evitar CORS.
# Ponlo en true solo si quieres forzar URL absoluta.
VITE_FORCE_ABSOLUTE_API=false

# Host del servidor Vite (nombre o IP accesible en la red)
VITE_DEV_HOST=0.0.0.0

# Agent system backend (Express) for /agent/* in dev proxy
VITE_AGENT_PROXY_TARGET=http://localhost:3000

# Optional absolute URL for the Agent API.
# Leave empty in local dev to use relative /agent/* routes + Vite proxy.
VITE_AGENT_BASE_URL=

# Frontend timeout for agent requests (ms)
VITE_AGENT_TIMEOUT_MS=45000
