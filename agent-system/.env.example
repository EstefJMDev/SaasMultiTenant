# Agent System Configuration

# Server
PORT=3000
NODE_ENV=development
AGENT_REQUEST_TIMEOUT_MS=45000

# ---------------------------------------------------------------------------
# LLM Provider: "ollama" (default, local) or "anthropic" (cloud)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# Ollama Configuration (local model - no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:31b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.1

# Anthropic API (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your-api-key-here
# CLAUDE_MODEL=claude-sonnet-4-20250514

# FastAPI Backend
FASTAPI_BASE_URL=http://localhost:8000
FASTAPI_API_KEY=

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_agents
DB_USER=agent_user
DB_PASSWORD=secure_password
DB_SSL=false
DB_POOL_MAX=20
DB_POOL_MIN=2

# Session Configuration
SESSION_TTL_MINUTES=30
CONFIRMATION_EXPIRY_MINUTES=5
MAX_AGENT_LOOP_ROUNDS=15

# API Client Settings
API_TIMEOUT_MS=15000
API_MAX_RETRIES=3

# Logging
LOG_LEVEL=info
DEBUG_API_CALLS=false
LOG_API_REQUESTS=true

# Multi-tenant
REQUIRE_TENANT_ID=true
